{
  "manifest_version": 3,
  "name": "IO Detector",
  "version": "0.0.1",
  "description": "DevTools for IntersectionObserver — visualize rootMargin, detect zombie observers, monitor visibility.",
  "minimum_chrome_version": "114",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "devtools_page": "src/devtools.html",
  "permissions": ["scripting"],
  "host_permissions": ["<all_urls>"],
  "web_accessible_resources": [
    {
      "resources": ["io-detector.bundle.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
